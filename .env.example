# ============================================================
# ClassPulse Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- App ---
ENVIRONMENT=development          # development | production
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=true

# --- Database (PostgreSQL) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=classpulse
POSTGRES_USER=classpulse_user
POSTGRES_PASSWORD=change-me-in-production

# Assembled automatically from above — don't edit this line
DATABASE_URL=postgresql://classpulse_user:change-me-in-production@db:5432/classpulse

# --- Redis (optional, used for WebSocket pub/sub at scale) ---
REDIS_URL=redis://redis:6379

# --- ML ---
MODEL_PATH=/app/ml_pipeline/models/saved_models

# --- CORS (comma-separated list of allowed origins) ---
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080
